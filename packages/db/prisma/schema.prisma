generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DRIVER
  OWNER
  FLEET_OPERATOR
  ADMIN
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum SyncStatus {
  SYNCING
  ACTIVE
  COMPLETED
  FAILED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(DRIVER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  driverProfile  DriverProfile?
  vehicles       Vehicle[]
  fleetOperator  FleetOperator?

  @@index([email])
  @@index([role])
}

model DriverProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  seatConfig          Json     @default("{}")
  mirrorConfig        Json     @default("{}")
  climateConfig       Json     @default("{}")
  infotainmentConfig  Json     @default("{}")
  drivingMode         Json     @default("{}")
  accessibility       Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncSessions SyncSession[] @relation("DriverSessions")

  @@index([userId])
}

model Vehicle {
  id        String        @id @default(uuid())
  ownerId   String
  make      String
  model     String
  year      Int
  vin       String        @unique
  status    VehicleStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  owner        User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  capabilities VehicleCapability[]
  fleetVehicles FleetVehicle[]
  syncSessions SyncSession[]       @relation("VehicleSessions")

  @@index([ownerId])
  @@index([vin])
  @@index([status])
}

model VehicleCapability {
  id             String @id @default(uuid())
  vehicleId      String
  category       String
  supportedRange Json

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([category])
}

model FleetOperator {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fleets Fleet[]

  @@index([userId])
}

model Fleet {
  id         String   @id @default(uuid())
  operatorId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  operator FleetOperator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  vehicles FleetVehicle[]

  @@index([operatorId])
}

model FleetVehicle {
  id        String   @id @default(uuid())
  fleetId   String
  vehicleId String
  addedAt   DateTime @default(now())

  fleet   Fleet   @relation(fields: [fleetId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([fleetId, vehicleId])
  @@index([fleetId])
  @@index([vehicleId])
}

model SyncSession {
  id        String     @id @default(uuid())
  driverId  String
  vehicleId String
  status    SyncStatus @default(SYNCING)
  syncPlan  Json       @default("{}")
  startedAt DateTime   @default(now())
  endedAt   DateTime?

  driver  DriverProfile @relation("DriverSessions", fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle       @relation("VehicleSessions", fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([vehicleId])
  @@index([status])
  @@index([startedAt])
}
