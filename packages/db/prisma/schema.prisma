generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DRIVER
  OWNER
  FLEET_OPERATOR
  ADMIN
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum SyncStatus {
  SYNCING
  ACTIVE
  COMPLETED
  FAILED
}

enum DDIStatus {
  ACTIVE
  REVOKED
  SUSPENDED
}

enum PresentationStatus {
  PENDING
  PRESENTED
  VERIFIED
  EXPIRED
  REJECTED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(DRIVER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  driverProfile  DriverProfile?
  digitalIdentity DigitalDrivingIdentity?
  vehicles       Vehicle[]
  fleetOperator  FleetOperator?

  @@index([email])
  @@index([role])
}

model DigitalDrivingIdentity {
  id              String    @id @default(uuid())
  ddiCode         String    @unique
  userId          String    @unique
  holderName      String
  homeCity        String
  status          DDIStatus @default(ACTIVE)
  identity        Json      @default("{\"verified\":true,\"biometric\":true}")
  licenses        Json      @default("[]")
  insurance       Json      @default("[]")
  mobilityNeeds   Json      @default("{}")
  languages       Json      @default("[\"en\"]")
  payment         Json      @default("{\"primary\":\"Mobility Wallet\"}")
  aiPersona       Json      @default("{\"tone\":\"concise\"}")
  trustedNetworks Json      @default("[]")
  trustScore      Int       @default(900)
  issuedAt        DateTime  @default(now())
  revokedAt       DateTime?
  updatedAt       DateTime  @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  presentationSessions  PresentationSession[]

  @@index([ddiCode])
  @@index([status])
}

model DriverProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  seatConfig          Json     @default("{}")
  mirrorConfig        Json     @default("{}")
  climateConfig       Json     @default("{}")
  infotainmentConfig  Json     @default("{}")
  drivingMode         Json     @default("{}")
  accessibility       Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncSessions SyncSession[] @relation("DriverSessions")

  @@index([userId])
}

model Vehicle {
  id           String        @id @default(uuid())
  ownerId      String
  make         String
  model        String
  year         Int
  vin          String        @unique
  externalId   String?       @unique
  status       VehicleStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  owner                 User                    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  capabilities          VehicleCapability[]
  fleetVehicles         FleetVehicle[]
  syncSessions          SyncSession[]           @relation("VehicleSessions")
  presentationSessions  PresentationSession[]

  @@index([ownerId])
  @@index([vin])
  @@index([externalId])
  @@index([status])
}

model VehicleCapability {
  id             String @id @default(uuid())
  vehicleId      String
  category       String
  supportedRange Json

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([category])
}

model PresentationSession {
  id            String             @id @default(uuid())
  challenge     String             @unique
  vehicleId     String
  ddiId         String?
  status        PresentationStatus @default(PENDING)
  disclosedFields Json             @default("[]")
  expiresAt     DateTime
  presentedAt   DateTime?
  verifiedAt    DateTime?
  syncSessionId String?
  createdAt     DateTime           @default(now())

  vehicle Vehicle                 @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  ddi     DigitalDrivingIdentity? @relation(fields: [ddiId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([ddiId])
  @@index([status])
  @@index([expiresAt])
}

model FleetOperator {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fleets Fleet[]

  @@index([userId])
}

model Fleet {
  id         String   @id @default(uuid())
  operatorId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  operator FleetOperator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  vehicles FleetVehicle[]

  @@index([operatorId])
}

model FleetVehicle {
  id        String   @id @default(uuid())
  fleetId   String
  vehicleId String
  addedAt   DateTime @default(now())

  fleet   Fleet   @relation(fields: [fleetId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([fleetId, vehicleId])
  @@index([fleetId])
  @@index([vehicleId])
}

model SyncSession {
  id        String     @id @default(uuid())
  driverId  String
  vehicleId String
  status    SyncStatus @default(SYNCING)
  syncPlan  Json       @default("{}")
  startedAt DateTime   @default(now())
  endedAt   DateTime?

  driver  DriverProfile @relation("DriverSessions", fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle       @relation("VehicleSessions", fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([vehicleId])
  @@index([status])
  @@index([startedAt])
}
