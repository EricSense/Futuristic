{
  "name": "futuristic",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "npm run generate -w @futuristic/db",
    "db:push": "npm run push -w @futuristic/db",
    "db:seed": "npm run seed -w @futuristic/db"
  },
  "devDependencies": {
    "next": "^14.2.35",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
